generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SavedJob {
  id          String   @id @default(cuid())
  title       String
  company     String
  location    String
  description String?
  link        String?
  contact     String?
  salary      String?
  source      String?
  status      String   @default("no_reply")
  notes       String?
  savedAt     DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
